@startuml c4_nivel1_contexto

' usa a lib oficial do C4 Model
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title [Nivel 1] Contexto do Sistema - Academic Events API

' atores externos que interagem com o sistema
Person(usuario, "Usuario", "Participante da plataforma.\nPode se inscrever em eventos,\ncommentar e reagir.")

Person(organizador, "Organizador", "Usuario que cria e gerencia\nEventos academicos na plataforma.")

' sistema principal que estamos documentando
System(api, "Academic Events API", "API REST em ASP.NET Core para\ngerenciar eventos academicos,\ninscricoes, comentarios e reacoes.\nAutenticacao via JWT Bearer Token.")

' sistema externo de persistencia
System_Ext(postgres, "PostgreSQL", "Banco de dados relacional.\nArmazena usuarios, eventos,\ninscricoes, comentarios e reacoes.")

' sistema externo de documentacao (gerado automaticamente)
System_Ext(swagger, "Swagger / OpenAPI", "Interface de documentacao e teste\ndos endpoints da API. Gerada\nautomaticamente pelo ASP.NET Core.")

' relacionamentos
Rel(usuario, api, "Busca eventos, se inscreve,\ncomenta e reage", "HTTPS / JSON")
Rel(organizador, api, "Cria, edita e cancela eventos", "HTTPS / JSON")
Rel(api, postgres, "Le e grava todos os dados\nda plataforma", "EF Core / Npgsql / SQL")
Rel(usuario, swagger, "Testa endpoints durante\no desenvolvimento", "HTTP")
Rel(organizador, swagger, "Testa endpoints durante\no desenvolvimento", "HTTP")

@enduml
